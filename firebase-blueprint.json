{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core user account data with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "customMonthlyFee": { "type": "number", "description": "Optional custom monthly fee for this student" }
      },
      "required": ["uid", "email", "name", "role", "status", "createdAt"]
    },
    "StudentProfile": {
      "title": "StudentProfile",
      "description": "Detailed physical and goal information for a student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "age": { "type": "number" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "goal": { "type": "string" },
        "restrictions": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "updatedAt"]
    },
    "StudentStats": {
      "title": "StudentStats",
      "description": "Gamification stats for a student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "currentStreak": { "type": "number" },
        "longestStreak": { "type": "number" },
        "lastCheckInDate": { "type": "string" },
        "badges": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "currentStreak", "longestStreak", "badges", "updatedAt"]
    },
    "WorkoutPlan": {
      "title": "WorkoutPlan",
      "description": "A workout plan assigned to a student by a teacher.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "studentId": { "type": "string" },
        "exercises": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "sets": { "type": "number" },
              "reps": { "type": "number" },
              "restSeconds": { "type": "number" },
              "notes": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "teacherId", "studentId", "exercises", "createdAt"]
    },
    "CheckIn": {
      "title": "CheckIn",
      "description": "A record of a student's gym attendance.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between users.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "content", "timestamp"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "A global announcement from admin.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId", "timestamp"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "general": { "type": "object" },
        "payment": { "type": "object" },
        "notifications": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores core user data and roles."
    },
    "/studentProfiles/{userId}": {
      "schema": { "$ref": "#/entities/StudentProfile" },
      "description": "Stores detailed student metrics. ID matches User ID."
    },
    "/studentStats/{userId}": {
      "schema": { "$ref": "#/entities/StudentStats" },
      "description": "Stores gamification stats. ID matches User ID."
    },
    "/workoutPlans/{planId}": {
      "schema": { "$ref": "#/entities/WorkoutPlan" },
      "description": "Stores workout plans assigned to students."
    },
    "/checkIns/{checkInId}": {
      "schema": { "$ref": "#/entities/CheckIn" },
      "description": "Stores student check-in records."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores direct messages."
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Stores global announcements."
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Stores global app settings."
    }
  }
}
